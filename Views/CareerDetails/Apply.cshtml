                                                                                            <div class="modal-dialog">
                                                                                                <div class="modal-content">
                                                                                                    <div class="modal-header">
                                                                                                        <h4 class="modal-title">Privacy Policy</h4>
                                                                                                        <button type="button" class="btn-closee" data-bs-dismiss="modal">X</button>
                                                                                                    </div>
