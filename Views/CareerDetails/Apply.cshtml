                                                                                                    </span>
                                                                                                </h6>
                                                                                            </a>
                                                                                        </h5>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="col-lg-2 col-md-4 p-0 shot-line">
                                                                                    <div class="set-two-content">
                                                                                        <h1>Digital Marketing <br><span>Strategist</span></h1>
                                                                                        <p>View &amp; Apply</p>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="col-lg-2 col-md-4 shot-line-two" style="padding:0 39px;">
                                                                                    <div class="set-two-content">
                                                                                        <h1>Content <br><span>Writer</span></h1>
                                                                                        <p>View &amp; Apply</p>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="col-lg-2 col-md-4 p-0">
                                                                                    <div class="set-two-content set-two-content-right">
                                                                                        <h1>Client Services <br><span>Manager</span></h1>
                                                                                        <p>View &amp; Apply</p>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        <!-- set three end -->

                                                                    </div>
                                                                </div>
