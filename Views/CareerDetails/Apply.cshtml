                                                                                    </div>
                                                                                    <!-- footer bottom end -->
                                                                                    <!-- thank you modal — NOT CHANGED -->
                                                                                    <div id="thankyou" class="modal success" style="display:none;">
                                                                                        <div class="modal-dialog modal-dialog-centered">
                                                                                            <div class="modal-content">
                                                                                                <div class="modal-header">
                                                                                                    <p id="closethankyou" class="btn-closee close" style="cursor:pointer;">X</p>
                                                                                                </div>
                                                                                                <div class="modal-body">
                                                                                                    <div class="p-3 text-center">
                                                                                                        <h1><img src="~/assets/img/tick-duffl.svg" alt="Success"></h1>
                                                                                                        <h4 class="pt-3" style="font-size:30px;">Thank you!</h4>
                                                                                                        <p>Your application has been submitted.</p>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                    <!-- thank you modal end -->
                                                                                    <!-- scripts -->
                                                                                    <script src="~/assets/js/jquery.min.js"></script>
                                                                                    <script src="~/assets/js/aos.js"></script>
                                                                                    <script src="~/assets/js/jquery.fancybox.min.js"></script>
                                                                                    <script src="~/assets/js/bootstrap-bundle.min.js"></script>
                                                                                    <script src="~/assets/js/main.js"></script>
                                                                                    <script src="~/assets/js/new-header.js"></script>
                                                                                    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
                                                                                    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

                                                                                    <script>
                                                                                        AOS.init();

                                                                                        // ===== Thank You Popup =====
                                                                                        @if (TempData["Success"] != null)
                                                                                        {
                                                                                            <text>
                                                                                                document.getElementById('thankyou').style.display = 'flex';
                                                                                            </text>
                                                                                        }

                                                                                        document.getElementById('closethankyou').addEventListener('click', function () {
                                                                                        document.getElementById('thankyou').style.display = 'none';
                                                                                        });

                                                                                        // ===== Show/Hide Experienced Fields =====
                                                                                        document.getElementById('ddlExperience').addEventListener('change', function () {
                                                                                        var val = this.value;
                                                                                        if (val === 'Experienced') {
                                                                                        document.getElementById('experiencedFields').style.display = 'block';
                                                                                        } else {
                                                                                        document.getElementById('experiencedFields').style.display = 'none';
                                                                                        document.getElementById('employedYesFields').style.display = 'none';
                                                                                        document.getElementById('employedNoFields').style.display  = 'none';
                                                                                        document.getElementById('ddlCurrentEmployed').value = '';
                                                                                        }
                                                                                        });

                                                                                        // ===== Show/Hide Currently Employed Yes/No =====
                                                                                        document.getElementById('ddlCurrentEmployed').addEventListener('change', function () {
                                                                                        var val = this.value;
                                                                                        if (val === 'Y') {
                                                                                        document.getElementById('employedYesFields').style.display = 'block';
                                                                                        document.getElementById('employedNoFields').style.display  = 'none';
                                                                                        } else if (val === 'N') {
                                                                                        document.getElementById('employedYesFields').style.display = 'none';
                                                                                        document.getElementById('employedNoFields').style.display  = 'block';
                                                                                        } else {
                                                                                        document.getElementById('employedYesFields').style.display = 'none';
                                                                                        document.getElementById('employedNoFields').style.display  = 'none';
                                                                                        }
                                                                                        });

                                                                                        // ===== Restore Fields on Validation Fail =====
                                                                                        window.addEventListener('DOMContentLoaded', function () {
                                                                                        var expVal = document.getElementById('ddlExperience').value;
                                                                                        if (expVal === 'Experienced') {
                                                                                        document.getElementById('experiencedFields').style.display = 'block';
                                                                                        var empVal = document.getElementById('ddlCurrentEmployed').value;
                                                                                        if (empVal === 'Y') {
                                                                                        document.getElementById('employedYesFields').style.display = 'block';
                                                                                        } else if (empVal === 'N') {
                                                                                        document.getElementById('employedNoFields').style.display = 'block';
                                                                                        }
                                                                                        }
                                                                                        });

                                                                                        // ===== Input Focus Animation — NOT CHANGED =====
                                                                                        document.querySelectorAll('input').forEach(function (input) {
                                                                                        input.addEventListener('focus', function () {
                                                                                        this.closest('.form-group')?.classList.add('focused');
                                                                                        });
                                                                                        input.addEventListener('blur', function () {
                                                                                        if (this.value === '') {
                                                                                        this.classList.remove('filled');
                                                                                        this.closest('.form-group')?.classList.remove('focused');
                                                                                        } else {
                                                                                        this.classList.add('filled');
                                                                                        }
                                                                                        });
                                                                                        });
                                                                                        // ===== FILE NAME DISPLAY AFTER UPLOAD =====
                                                                                        document.getElementById('flPaper').addEventListener('change', function () {
                                                                                      

                                                                                        var display = document.getElementById('fileNameDisplay');
                                                                                        //  ↑ gets the span where we show filename

                                                                                        if (this.files && this.files.length > 0) {

                                                                                        var fileName = this.files[0].name;
                                                                                        //  ↑ e.g. "MyResume.pdf"

                                                                                        var fileSize = (this.files[0].size / 1024 / 1024).toFixed(2);
                                                                                        //  ↑ converts bytes → MB  e.g. "0.85"

                                                                                        // Client side file size check
                                                                                        if (this.files[0].size > 5 * 1024 * 1024) {
                                                                                        // ❌ File too large
                                                                                        display.textContent = fileName + ' exceeds 5MB!';
                                                                                        display.style.color = '#ff4444';
                                                                                        this.value = ''; // clears the selection
                                                                                        } else {
                                                                                        // ✅ File ok — show name and size
                                                                                        display.textContent =  fileName + ' (' + fileSize + ' MB)';
                                                                                        display.style.color = '#aaa';
                                                                                        }

                                                                                        } else {
                                                                                        display.textContent = 'No file chosen';
                                                                                        display.style.color = '#aaa';
                                                                                        }
                                                                                        });
                                                                                    </script>
                                                                                    <!-- scripts end -->

                                                                                </body>
                                                                            </html>