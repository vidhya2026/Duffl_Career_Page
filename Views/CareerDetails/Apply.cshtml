                                                                            <!-- Application Form -->
                                                                            <div class="col-lg-6">
                                                                                <div class="form-right position-relative">

                                                                                    @if (TempData["Success"] != null)
                                                                                    {
                                                                                        <div class="alert alert-success mb-3">
                                                                                            @TempData["Success"]
                                                                                        </div>
                                                                                    }

                                                                                    <form method="post" asp-controller="CareerDetails"
                                                                                          asp-action="Apply" enctype="multipart/form-data">
                                                                                        @Html.AntiForgeryToken()
                                                                                        @Html.ValidationSummary(false, "",
                                                                                            new { @class = "text-danger" })

                                                                                        <!-- Name — NOT CHANGED -->
                                                                                        <div class="form-group input-margin">
                                                                                            <label class="form-label" for="Name">Name*</label>
                                                                                            <input asp-for="Name" id="Name"
                                                                                                   class="form-input" type="text" />
                                                                                            <span asp-validation-for="Name"
                                                                                                  class="text-danger"></span>
                                                                                        </div>

                                                                                        <!-- Email — NOT CHANGED -->
                                                                                        <div class="form-group input-margin">
                                                                                            <label class="form-label" for="Email">Email Id*</label>
                                                                                            <input asp-for="Email" id="Email"
                                                                                                   class="form-input" type="email" />
                                                                                            <span asp-validation-for="Email"
                                                                                                  class="text-danger"></span>
                                                                                        </div>

                                                                                        <!-- Mobile — NOT CHANGED -->
                                                                                        <div class="form-group input-margin">
                                                                                            <label class="form-label" for="MobileNumber">
                                                                                                Mobile Number*
                                                                                            </label>
                                                                                            <input asp-for="MobileNumber" id="MobileNumber"
                                                                                                   class="form-input" type="tel"
                                                                                                   maxlength="10"
                                                                                                   oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
                                                                                            <span asp-validation-for="MobileNumber"
                                                                                                  class="text-danger"></span>
                                                                                        </div>

                                                                                        <!-- Location — NOT CHANGED -->
                                                                                        <div class="form-group input-margin">
                                                                                            <label class="form-label" for="Location">Location*</label>
                                                                                            <input asp-for="Location" id="Location"
                                                                                                   class="form-input" type="text" />
                                                                                            <span asp-validation-for="Location"
                                                                                                  class="text-danger"></span>
                                                                                        </div>

                                                                                        <!-- Fresher / Experienced — NOT CHANGED -->
                                                                                        <div class="form-group input-margin">
                                                                                            <label class="form-label label-design mb-4"
                                                                                                   for="ExperienceLevel">Are you a*</label>
                                                                                            <select asp-for="ExperienceLevel"
                                                                                                    id="ddlExperience"
                                                                                                    class="custom-select sources mt-4 w-100 pt-4"
                                                                                                    asp-items='@(new SelectList(new[] {
                                                                                            new { Value = "",            Text = "Choose One"   },
                                                                                            new { Value = "Fresher",     Text = "Fresher"      },
                                                                                            new { Value = "Experienced", Text = "Experienced"  }
                                                                                        }, "Value", "Text"))'>
                                                                                            </select>
                                                                                            <span asp-validation-for="ExperienceLevel"
                                                                                                  class="text-danger"></span>
                                                                                        </div>

                                                                                        <!-- Expected Salary — NOT CHANGED -->
                                                                                        <div class="form-group input-margin">
                                                                                            <label class="form-label" for="ExpectedSalary">
                                                                                                Expected Salary
                                                                                            </label>
                                                                                            <input asp-for="ExpectedSalary" id="ExpectedSalary"
                                                                                                   class="form-input" type="number" min="0"
                                                                                                   oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
                                                                                            <span asp-validation-for="ExpectedSalary"
                                                                                                  class="text-danger"></span>
                                                                                        </div>

                                                                                        <!-- ===== NEW FIELDS — EXPERIENCED ONLY ===== -->
                                                                                        <div id="experiencedFields" style="display:none;">

                                                                                            <!-- Currently Employed -->
                                                                                            <div class="form-group input-margin">
                                                                                                <label class="form-label label-design mb-4">
                                                                                                    Currently Employed*
                                                                                                </label>
                                                                                                <select asp-for="CurrentlyEmployed"
                                                                                                        id="ddlCurrentEmployed"
                                                                                                        class="custom-select sources mt-4 w-100 pt-4">
                                                                                                    <option value="">Choose One</option>
                                                                                                    <option value="Y">Yes</option>
                                                                                                    <option value="N">No</option>
                                                                                                </select>
                                                                                                <span asp-validation-for="CurrentlyEmployed"
                                                                                                      class="text-danger"></span>
                                                                                            </div>

                                                                                            <!-- Work Experience — decimal only -->
                                                                                            <div class="form-group input-margin">
                                                                                                <label class="form-label">
                                                                                                    Work Experience (Years)*
                                                                                                </label>
                                                                                                <input asp-for="WorkExperience"
                                                                                                       class="form-input"
                                                                                                       type="number"
                                                                                                       step="0.5"
                                                                                                       min="0"
                                                                                                       max="50"
                                                                                                     
                                                                                                       oninput="this.value=this.value.replace(/[^0-9.]/g,'')" />
                                                                                                <span asp-validation-for="WorkExperience"
                                                                                                      class="text-danger"></span>
                                                                                            </div>

                                                                                            <!-- Currently Employed = YES fields -->
                                                                                            <div id="employedYesFields" style="display:none;">

                                                                                                <div class="form-group input-margin">
                                                                                                    <label class="form-label">
                                                                                                        Current Employer Name*
                                                                                                    </label>
                                                                                                    <input asp-for="CurrentEmployerName"
                                                                                                           class="form-input" type="text"
                                                                                                           />
                                                                                                    <span asp-validation-for="CurrentEmployerName"
                                                                                                          class="text-danger"></span>
                                                                                                </div>

                                                                                                <div class="form-group input-margin">
                                                                                                    <label class="form-label">
                                                                                                        Current Drawn Salary*
                                                                                                    </label>
                                                                                                    <input asp-for="CurrentDrawnSalary"
                                                                                                           class="form-input" type="number" min="0"
                                                                                                          
                                                                                                           oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
                                                                                                    <span asp-validation-for="CurrentDrawnSalary"
                                                                                                          class="text-danger"></span>
                                                                                                </div>

                                                                                                <div class="form-group input-margin">
                                                                                                    <label class="form-label">Notice Period*</label>
                                                                                                    <input asp-for="NoticePeriod"
                                                                                                           class="form-input" type="text"
                                                                                                          />
                                                                                                    <span asp-validation-for="NoticePeriod"
                                                                                                          class="text-danger"></span>
                                                                                                </div>

                                                                                            </div>
                                                                                            <!-- YES fields end -->
                                                                                            <!-- Currently Employed = NO fields -->
                                                                                            <div id="employedNoFields" style="display:none;">

                                                                                                <div class="form-group input-margin">
                                                                                                    <label class="form-label">
                                                                                                        Last Employer Name*
                                                                                                    </label>
                                                                                                    <input asp-for="LastEmployerName"
                                                                                                           class="form-input" type="text"
                                                                                                           placeholder="Enter last employer name" />
                                                                                                    <span asp-validation-for="LastEmployerName"
                                                                                                          class="text-danger"></span>
                                                                                                </div>

                                                                                                <div class="form-group input-margin">
                                                                                                    <label class="form-label">
                                                                                                        Last Drawn Salary*
                                                                                                    </label>
                                                                                                    <input asp-for="LastDrawnSalary"
                                                                                                           class="form-input" type="number" min="0"
                                                                                                           placeholder="Enter last drawn salary"
                                                                                                           oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
                                                                                                    <span asp-validation-for="LastDrawnSalary"
                                                                                                          class="text-danger"></span>
                                                                                                </div>

                                                                                            </div>
                                                                                            <!-- NO fields end -->

                                                                                        </div>
                                                                                        <!-- FILE UPLOAD -->
                                                                                        <div class="file-upload-wrapper input-margin"
                                                                                             >

                                                                                     
                                                                                            <input type="file"
                                                                                                   name="CvFile"
                                                                                                   id="flPaper"
                                                                                                   class="file-upload-field"
                                                                                                   accept=".doc,.docx,.pdf">
                                                                                          
                                                                                            <span id="fileNameDisplay"
                                                                                                  style="color:#aaa; font-size:13px;
                                                                                                display:block; margin-top:8px;">
                                                                                                No file chosen
                                                                                            </span>

                                                                                            <span class="notelabel"
                                                                                                  style="position:static; margin-top:8px; display:block;">
                                                                                                (.doc, .docx, .pdf) file size not to exceed 5 MB
                                                                                            </span>

                                                                                            @if (ViewData.ModelState["CvFile"]?.Errors.Count > 0)
                                                                                            {
                                                                                                <span class="text-danger">
                                                                                                    @ViewData.ModelState["CvFile"]!.Errors[0].ErrorMessage
                                                                                                </span>
                                                                                            }
                                                                                        </div>

                                                                                        <!-- Captcha — NOT CHANGED -->
                                                                                        <h3>Verify Captcha</h3>
                                                                                        <div class="d-flex" style="gap:10px;">
                                                                                            <h4>2 + 3 =</h4>
                                                                                            <input id="CaptchaAnswer" name="CaptchaAnswer"
                                                                                                   class="last-input" type="number" />
                                                                                        </div>
                                                                                        @if (TempData["CaptchaError"] != null)
                                                                                        {
                                                                                            <span class="text-danger">@TempData["CaptchaError"]</span>
                                                                                        }

                                                                                        <button type="submit">Submit</button>

                                                                                    </form>
                                                                                </div>
                                                                            </div>
                                                                            <!-- Application Form end -->

                                                                        </div>
                                                                    </div>
                                                                    <!-- set two end -->
                                                                    <!-- set three — NOT CHANGED -->
                                                                    <div class="set-three">
                                                                        <div class="row justify-content-between">
                                                                            <div class="col-lg-4 col-md-12">
                                                                                <div class="set-one-content">
                                                                                    <h1>Other Opportunities</h1>
                                                                                    <p>
                                                                                        Discover a range of exciting roles at Duffl Digital that
                                                                                        align with your skills and passions.
