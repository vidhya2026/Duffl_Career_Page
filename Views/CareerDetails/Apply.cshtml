                                                                                    <!-- footer end -->
                                                                                    <!-- footer bottom — NOT CHANGED -->
                                                                                    <div class="footer-bottom">
                                                                                        <div class="container">
                                                                                            <div class="row">
                                                                                                <div class="col-lg-4 text-lg-start text-center py-lg-2 pt-2">
