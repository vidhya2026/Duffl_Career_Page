                                                                                                    <a href="https://www.facebook.com/duffldigital"
                                                                                                           target="_blank" rel="noopener">
                                                                                                        <img alt="Facebook" src="~/assets/img/footer/fb.svg">
                                                                                                        </a>
                                                                                                    </div>
                                                                                                </div>
                                                                                                <div class="col-lg-4 col-md-4 col-sm-4 col-5">
