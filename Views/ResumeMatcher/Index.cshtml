@{
    ViewData["Title"] = "Resume Screening";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">

    <div class="mb-4">
        <h2>Resume Screening Tool</h2>
        <p class="text-muted">Enter the job description and upload candidate resumes.</p>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-4">

            <form method="post" action="/ResumeMatcher/Match" enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Job Description <span class="text-danger">*</span>
                    </label>
                    <textarea name="jobDescription"
                              class="form-control"
                              rows="8"
                              placeholder="Paste the full job description here..."
                              required></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Upload Resumes <span class="text-danger">*</span>
                    </label>
                    <input type="file"
                           name="resumes"
                           class="form-control"
                           accept=".pdf,.docx,.txt"
                           multiple
                           required />
                    <div class="form-text mt-1">
                        Accepted formats: PDF, DOCX, TXT &nbsp;&bull;&nbsp; Maximum 10 files
                    </div>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <button type="submit" class="btn btn-primary px-4 py-2" id="submitBtn">
                        Analyse Resumes
                    </button>
                    <span class="text-muted small" id="loadingText" style="display:none;">
                        Please wait, BERT model is analysing resumes...
                    </span>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelector('form').addEventListener('submit', function () {
            document.getElementById('loadingText').style.display = 'inline';
            document.getElementById('submitBtn').disabled = true;
        });
    </script>
}